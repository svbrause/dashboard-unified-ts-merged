# Dashboard (Vite) — optional; defaults still hit your backend base URL.
# Copy to `.env.local` for local dev.

# The Treatment only: show Post-Visit share link, Analysis Overview, wellness overview block, etc.
# Omit in production until those features launch. Wellnest and admin logins ignore this.
# VITE_THE_TREATMENT_PREVIEW_FEATURES=true

# Backend that serves /api/* (assessment, blueprint, etc.)
# VITE_BACKEND_API_URL=https://your-backend.example.com

# ── Post-Visit Blueprint: Listen (Google Cloud Text-to-Speech via your backend) ──
# Backend POST endpoint: JSON { text, voiceName?, languageCode? } → audio/mpeg
# VITE_GOOGLE_TTS_PROXY_URL=https://your-backend.example.com/api/tts/google-cloud
# VITE_GOOGLE_TTS_VOICE_NAME=en-US-Neural2-F
# VITE_GOOGLE_TTS_LANGUAGE_CODE=en-US

# Optional: show “Gemini” wordmark next to AI UI (default: hidden)
# VITE_SHOW_GEMINI_BRAND=true

# Wellnest1300: in `npm run dev`, demo patients with peptide plans are merged after API fetch (default on).
# Set false to only show live Airtable rows. Set true to inject demos in production builds (e.g. staging).
# VITE_WELLNEST_SAMPLE_CLIENTS=false
# Optional: replace stock Wellnest demo headshots with real demo-environment photo URLs
# VITE_WELLNEST_DEMO_HEADSHOT_ALEX=https://...
# VITE_WELLNEST_DEMO_HEADSHOT_JORDAN=https://...
# VITE_WELLNEST_DEMO_HEADSHOT_TAYLOR=https://...

# Local-only: Analysis Overview AI text via Gemini (Vite proxy; key ends up in bundle — not for production)
# VITE_GEMINI_API_KEY=your-google-ai-studio-key
# VITE_GEMINI_MODEL=gemini-2.0-flash
# Optional localhost fallback when Gemini returns 429 (also exposed in bundle):
# VITE_OPENAI_API_KEY=your-openai-key
# VITE_OPENAI_MODEL=gpt-4o-mini

# Optional: deterministic hero image URL if backend does not set frontPhotoPersistentUrl
# VITE_BLUEPRINT_HERO_PHOTO_URL_TEMPLATE=https://storage.googleapis.com/bucket/blueprints/{token}/front.jpg

# ── Server-side (Vercel / backend — NOT in this file) ──
# Overview, category, and PVB treatment chapters: configure LLM on the server (keys stay off the client):
#   POST /api/assessment, /api/category-assessment, /api/pvb/treatment-chapter-overview
#   GEMINI_API_KEY=...         # AI Studio (optional if using Vertex)
#   LLM_PROVIDER=gemini|openai|vertex
#   GEMINI_MODEL=gemini-2.0-flash
#
# Vertex AI (Gemini on GCP — often where GCP credits apply; no API key):
#   LLM_PROVIDER=vertex
#   VERTEX_PROJECT_ID=your-gcp-project   # optional if project_id is inside GCS_SERVICE_ACCOUNT_JSON
#   VERTEX_LOCATION=us-central1
#   VERTEX_GEMINI_MODEL=gemini-2.0-flash-001
#   GCS_SERVICE_ACCOUNT_JSON={...}     # same SA pattern as TTS/GCS, or GOOGLE_APPLICATION_CREDENTIALS locally
# Enable “Vertex AI API” on the project; grant the SA aiplatform.user (or Vertex AI User).
#
# If both GEMINI_API_KEY and Vertex are configured, default provider stays Gemini unless LLM_PROVIDER=vertex.
# Optional: OPENAI_API_KEY + LLM_PROVIDER=openai.
# TTS: implement route matching VITE_GOOGLE_TTS_PROXY_URL using @google-cloud/text-to-speech
# GCS hero: GCS_BLUEPRINT_BUCKET, GCS_SERVICE_ACCOUNT_JSON (see backend docs)
#
# SMS (dashboard OpenPhone + Airtable — implement on backend, not in this Vite app):
#   POST /api/dashboard/sms → OpenPhone, then create row in **SMS Notifications Logs** only
#     (not **SMS Notifications**, if that table triggers Zapier → OpenPhone and would duplicate sends).
#   GET /api/dashboard/sms-notifications → merge **SMS Notifications** + **SMS Notifications Logs**,
#     same field mapping (phone, message, name, created time), sort newest first, then paginate/search.
